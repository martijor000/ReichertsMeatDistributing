@using ReichertsMeatDistributing.Shared;
@inherits LayoutComponentBase


<head>
    <style>
        body {
            font-family: Arial, Helvetica, sans-serif;
            margin: 0;
        }

        .container {
            margin: 0px;
            padding: 0px;
        }

        /* Navbar background styling */
        .navbar {
            background-color: #F2F2F2; /* Light gray */
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 0px;
        }

        /* Navbar brand/logo styles */
        .navbar-brand {
            text-align: center;
            text-decoration: none;
            margin: 0;
            padding: 0;
            display: inline-block;
            padding: 20px;
        }

        #one {
            font-family: 'Brush Script MT';
            color: darkred;
            font-size: 80px;
            line-height: 1.0;
            margin: 0;
        }

        #two {
            background-color: #0f3923;
            font-family: 'Georgia', 'Times New Roman', serif;
            font-weight: bold;
            color: white;
            line-height: 20px;
            font-size: 20px;
            margin: 0;
            letter-spacing: 5px;
        }

        /* Navigation links */
        .nav-container {
            display: flex;
            justify-content: center;
            gap: 20px; /* Space between links */
            width: 100%;
            padding-bottom: 10px;
        }

        .nav-item {
            display: flex; /* Use flex to keep "Contact Us" inline */
            justify-content: center;
            align-items: center;
            width: 100px;
            height: 50px;
        }

        .nav-link {
            color: black !important; /* Ensure black color for links */
            font-weight: bold;
            text-decoration: none;
            padding: 10px 15px;
            white-space: nowrap; /* Prevent text from wrapping */
            transition: color 0.3s ease;
        }

            .nav-link:hover {
                color: darkred !important; /* Hover color */
            }


        body {
            max-height: 100vh; /* Limit to viewport height */
        }
    </style>
</head>
<header>
    <nav class="navbar">
        <!-- Logo -->
        <div>
            <a class="navbar-brand" href="/">
                <div id="one">Reichert's</div>
                <div id="two">DISTRIBUTING</div>
            </a>
        </div>
        <!-- Navigation Links -->
        <div class="nav-container">
            <div class="nav-item">
                <a class="nav-link" href="/">Home</a>
            </div>
            <div class="nav-item">
                <a class="nav-link" href="/Products">Products</a>
            </div>
            <div class="nav-item">
                <a class="nav-link" href="/Contact">Contact Us</a>
            </div>
        </div>
    </nav>
</header>
<main>
    @Body
</main>

