@page "/Products"

@if (productList == null)
{
    <p>Loading products...</p>
}
else
{
    <div class="container">
        <div class="row justify-content-center text-center">
            @foreach (var product in productList)
            {
                <div class="col-md-4 d-flex justify-content-center">
                    <div class="card mb-4 shadow-sm" style="box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2); width: 100%;">
                        <div class="card-body text-center">
                            <p>@product.Description</p>
                            <p>@product.ItemId</p>
                            <p class="card-text">@product.StockingUm</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

