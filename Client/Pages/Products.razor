@page "/Products"
@inject IJSRuntime JSRuntime

<div class="filter-bar container-fluid m-0 ">
    <div class="p-2" style="background-color: lightcoral">
        <div class="row justify-content-center text-center">
            <div class="col-md-12">
                <input @bind="searchQuery" class="form-control" type="text" placeholder="Search for a product..." @oninput="HandleInput" />
            </div>
        </div>
    </div>
</div>

@if (filteredProducts == null)
{
    <p>Loading products...</p>
}
else if (!filteredProducts.Any())
{
    <p>No products found.</p>
}
else
{
    <div class="container">
        <div class="row justify-content-center text-center">
            @foreach (var product in filteredProducts)
            {
                <div class="col-md-4 d-flex justify-content-center">
                    <div class="card mb-4 shadow-sm" style="box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2); width: 100%;">
                        <div class="card-body text-center">
                            <p>@product.Description</p>
                            <p>@product.ItemId</p>
                            <p class="card-text">@product.StockingUm</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}




